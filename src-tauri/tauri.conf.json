{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KeyTweak",
  "version": "0.1.0",
  "identifier": "com.keytweak.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "title": "KeyTweak",
        "width": 900,
        "height": 650,
        "resizable": false,
        "visible": false,
        "skipTaskbar": false,
        "center": true,
        "decorations": false
      },
      {
        "label": "toast",
        "url": "toast.html",
        "title": "KeyTweak — Перевод",
        "width": 360,
        "height": 104,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "focus": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* https://*"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}

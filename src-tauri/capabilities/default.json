{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for KeyTweak windows: allow invoking app commands and core APIs.",
  "windows": ["settings", "toast"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-hide",
    "core:webview:default",
    "core:event:default",
    "core:app:default",
    "core:tray:default"
  ]
}
